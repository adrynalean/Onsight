# HuggingFace access token — needed to download gated models (e.g. Llama 3.1)
# and to push fine-tuned models to your own HF account.
# Create one at: https://huggingface.co/settings/tokens
huggingface_token=

# Where training should push your fine-tuned models.
# Example: adrynalean/one-piece-ability-classifier
ability_model_path=

# Example: adrynalean/one-piece-luffy-chatbot
luffy_model_path=
